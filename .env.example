# Copy this file to `.env` (gitignored) and fill in your values.
#
# Per-room relay token. Get it from a room's invite link:
#   node copy-skill.js 'https://live.slop.computer/<slug>?invite=...'
#   → prints .../v1/skill?token=<ROOM_TOKEN>&slug=…   ← paste the 64-hex token here
SLOP_TOKEN=

# Optional overrides (defaults shown):
# SLOP_BASE=https://live.slop.computer
# SLOP_COHOST=clawdbotatg
# SLOP_PORT_SOCIAL=9223
# SLOP_PORT_YT=9224
